<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Clean up conversation contexts inactive for more than 7 days -->
    <record id="jarvis_cleanup_cron" model="ir.cron">
        <field name="name">Jarvis: Clean up expired conversation contexts</field>
        <field name="model_id" ref="model_jarvis_context"/>
        <field name="state">code</field>
        <field name="code">model.cleanup_expired()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="numbercall">-1</field>
        <field name="active">True</field>
    </record>
</odoo>
